# Bridge endpoint (the URL of your Lovable app)
BRIDGE_URL=https://plan-crafted-joy.lovable.app/api/public/p21-bridge

# Shared secret — copy the value of P21_BRIDGE_SECRET from Lovable Cloud secrets
BRIDGE_SECRET=

# Friendly name for this agent (shown in the app)
AGENT_NAME=ndi-windows-01

# Polling interval in ms (default 5000)
POLL_INTERVAL_MS=5000

# P21 SQL Server connection (reachable while FortiClient VPN is up)
P21_SQL_HOST=p21sql.internal.example.com
P21_SQL_PORT=1433
P21_SQL_DB=P21Play
P21_SQL_USER=p21_readonly
P21_SQL_PASS=
P21_SQL_ENCRYPT=true
P21_SQL_TRUST_CERT=true

# P21 Data API (REST) — agent runs on the P21 server, so loopback is fine.
# Base URL is whatever IIS site the P21 middleware is published under.
P21_API_BASE_URL=http://localhost/P21APIService
# Consumer key generated in the P21 Middleware Configuration Utility.
P21_API_CONSUMER_KEY=
# Header name the consumer key is sent under during token exchange.
# Default "Authorization" works for most v12+ installs; some sites use
# "consumer-key" or "apiKey".
P21_API_CONSUMER_KEY_HEADER=Authorization
# Service account that owns the API session (separate from SQL creds).
P21_API_USERNAME=
P21_API_PASSWORD=
