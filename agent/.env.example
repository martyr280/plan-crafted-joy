# Bridge endpoint (the URL of your Lovable app)
BRIDGE_URL=https://plan-crafted-joy.lovable.app/api/public/p21-bridge

# Shared secret — copy the value of P21_BRIDGE_SECRET from Lovable Cloud secrets
BRIDGE_SECRET=

# Friendly name for this agent (shown in the app)
AGENT_NAME=ndi-windows-01

# Polling interval in ms (default 5000)
POLL_INTERVAL_MS=5000

# P21 SQL Server connection (reachable while FortiClient VPN is up)
P21_SQL_HOST=p21sql.internal.example.com
P21_SQL_PORT=1433
P21_SQL_DB=P21Play
P21_SQL_USER=p21_readonly
P21_SQL_PASS=
P21_SQL_ENCRYPT=true
P21_SQL_TRUST_CERT=true
